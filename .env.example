NODE_ENV=development
BASE_URL=0.0.0.0
PORT=8001

# Comma-separated list of full origins allowed by CORS.
# Admin dashboard dev server = 50523, merchant dashboard dev server = 50522.
ALLOWED_ORIGINS=

# Public URL of the merchant dashboard. Stripe Connect onboarding redirects back
# here, so it must be a full http(s) origin reachable from the merchant's browser.
MERCHANT_DASHBOARD_URL=

# MONGO_URL=mongodb://localhost:27017/laundryDB
MONGO_URL=

# Seeded admin account (created on server start if it does not exist).
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=

BCRYPT_SALT_ROUNDS=
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=
ACTIVATION_SECRET=

SMTP_HOST=
SMTP_PORT=
SMTP_MAIL=
SMTP_PASSWORD=
SMTP_SERVICE=
SERVICE_NAME=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_SECRET_LIVE=


# variables
EMAIL_TEMP_IMAGE=